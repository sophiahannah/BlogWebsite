@model IEnumerable<BlogWebsite.Models.Post>

@{
    ViewData["Title"] = "Home Feed";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Welcome to the Tech & Pastel Blog</h1>
        <p class="text-muted">Exploring tech with a soft aesthetic. 💛</p>
    </div>

    <div class="row">
        @foreach (var post in Model)
        {
            <div class="col-md-6 mb-4">
                <div class="card blog-card h-100 p-4">
                    <div class="card-body d-flex flex-column">
                        <small class="text-muted mb-2">📅 @post.CreatedAt.ToString("MMM dd, yyyy")</small>
                        <h3 class="card-title fw-bold">@post.Title</h3>
                        <p class="card-text text-muted flex-grow-1">@post.Summary</p>
                        <div class="mt-3">
                            <a asp-controller="Blog" asp-action="Details" asp-route-id="@post.Id" class="btn-pastel">Read Article →</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>