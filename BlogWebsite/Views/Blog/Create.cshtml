@model BlogWebsite.Models.Post
@{
    ViewData["Title"] = "Write Article";
}

<div class="container mt-5" style="max-width: 700px;">
    <h2 class="fw-bold mb-4">Write a New Article</h2>
    
    <div class="bg-white p-4 rounded-4 shadow-sm border" style="border-color: var(--border-color) !important;">
        <form asp-action="Create">
            <div class="mb-3">
                <label class="form-label fw-bold">Title</label>
                <input asp-for="Title" class="form-control" placeholder="Enter an eye-catching title..." required />
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Summary</label>
                <textarea asp-for="Summary" class="form-control" rows="2" placeholder="Briefly describe what this is about..." required></textarea>
            </div>
            <div class="mb-4">
                <label class="form-label fw-bold">Full Content</label>
                <textarea asp-for="Content" class="form-control" rows="6" placeholder="Write your full article here..." required></textarea>
            </div>
            
            <button type="submit" class="btn-pastel border-0 px-4 py-2">Publish Article</button>
            <a asp-action="Index" class="btn btn-link text-muted ms-2">Cancel</a>
        </form>
    </div>
</div>